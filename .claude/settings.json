      "Bash(gh auth *)"
    ],
    "allowMultilineCommands": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/git-auto-stage.sh\"'"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/save-plan.sh\"'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hooks/open-pdf-after-typst.sh\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -lc 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); node_bin=$(command -v node || ls -t \"$HOME\"/.nvm/versions/node/*/bin/node 2>/dev/null | head -1 || echo /usr/local/bin/node); exec \"$node_bin\" \"${plugin_dir}dist/index.js\"'"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "ksrc@respawn-tools": true,
    "claude-code-setup@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "firebase@firebase": false,
    "superpowers@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "respawn-tools": {
      "source": {
        "source": "github",
        "repo": "respawn-app/claude-plugin-marketplace"
      }
    },
    "firebase": {
      "source": {
        "source": "github",
        "repo": "firebase/firebase-tools"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "ukrainian-sergeant-market": {
      "source": {
        "source": "github",
        "repo": "satanyakiv/claude-4.5.0"
      }
    }
  },
  "language": "Ukrainian",
  "effortLevel": "high",
  "voiceEnabled": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true
}
